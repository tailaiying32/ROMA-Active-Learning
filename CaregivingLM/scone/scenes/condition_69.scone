CmaOptimizer {
	signature_prefix = DATE_TIME
	enable_boundary_transformer = 1
	random_seed = 42
	flat_fitness_epsilon = 1e-6
	window_size = 1000
	min_progress = 1e-5

	SimulationObjective {
		$rest_dur = 1
		$trg_dur = 1.5
		$react_dur = 1.0
		signature_postfix = T10
		max_duration = 3
		
		ModelHyfydyPrecise {
			model_file = ../models/HSA13T-2025-06-26.hfd
			state_init_file = ../init/InitHSA13_bs.zml
			fixed_control_step_size = 0.005
			zero_velocity_equilibration = 1
			
			model_options {
				use_legacy_pin_joints = 0
				joint_rotational_damping = 0.02
			}

			Properties {
				trap_scap_m_r {max_isometric_force.factor = 0.124939}
				trap_scap_s_r {max_isometric_force.factor = 0.124211}
				trap_scap_i_r {max_isometric_force.factor = 0.061293}
				trap_clav_s_r {max_isometric_force.factor = 0.092192}
				ser_ant_i_r {max_isometric_force.factor = 0.122052}
				ser_ant_m_r {max_isometric_force.factor = 0.124268}
				ser_ant_s_r {max_isometric_force.factor = 0.143210}
				rhom_s_r {max_isometric_force.factor = 0.073250}
				rhom_i_r {max_isometric_force.factor = 0.015116}
				lev_scap_r {max_isometric_force.factor = 0.025491}
				pect_min_r {max_isometric_force.factor = 0.240711}
				delt_clav_a_r {max_isometric_force.factor = 0.124566}
				delt_scap_p_r {max_isometric_force.factor = 0.244676}
				delt_scap_m_r {max_isometric_force.factor = 0.147079}
				lat_dors_m_r {max_isometric_force.factor = 0.126333}
				lat_dors_i_r {max_isometric_force.factor = 0.083146}
				pect_maj_clav_s_r {max_isometric_force.factor = 0.117611}
				pect_maj_thorax_i_r {max_isometric_force.factor = 0.154718}
				pect_maj_thorax_m_r {max_isometric_force.factor = 0.065209}
				teres_maj_r {max_isometric_force.factor = 0.043945}
				infraspi_i_r {max_isometric_force.factor = 0.094218}
				infraspi_s_r {max_isometric_force.factor = 0.034855}
				teres_min_r {max_isometric_force.factor = 0.248188}
				subscap_s_r {max_isometric_force.factor = 0.122592}
				subscap_i_r {max_isometric_force.factor = 0.115429}
				supraspi_r {max_isometric_force.factor = 0.059372}
				tri_long_r {max_isometric_force.factor = 0.093115}
				tri_lat_r {max_isometric_force.factor = 0.051565}
				coracobrach_r {max_isometric_force.factor = 0.082999}
				bic_long_r {max_isometric_force.factor = 0.276973}
				bic_brev_r {max_isometric_force.factor = 0.062655}
				brach_r {max_isometric_force.factor = 0.049627}
				brachiorad_r {max_isometric_force.factor = 0.051265}
				supinator_r {max_isometric_force.factor = 0.160268}
				pronator_teres_r {max_isometric_force.factor = 0.059816}
				ext_carpi_rad_long_r {max_isometric_force.factor = 0.243983}
				ext_carpi_rad_brev_r {max_isometric_force.factor = 0.050897}
				ext_carpi_ulna_r {max_isometric_force.factor = 0.066403}
				flex_carpi_rad_r {max_isometric_force.factor = 0.061844}
				flex_carpi_ulna_r {max_isometric_force.factor = 0.060610}
			}
		}
		
		# Sequential FeedForward Controller
		SequentialController {
			transition_intervals = [ $rest_dur ]
			FeedForwardController { name = Relax1 Constant { value = 0.01 } }
			
			FeedForwardController {
				include = "*_r"
				PieceWiseLinear {
					control_points = 2
					control_point_y = 0.015~0.001<0,1>
					control_point_dt = 0.4~0.01<0.1,1.0>
					flat_extrapolation = 1
				}
			}
		}
		
		# Reaching Measure
		CompositeMeasure {
			use_first_non_zero_result = 1
			ScriptMeasure {
				weight = 100
				threshold = 0.05
				vel_penalty = 0.2
				start_time = $rest_dur
				target_duration = $trg_dur
				react_time = $react_dur
				show_target = 1
				minimize = 1
				target_body = "hand_r"
				script_file = "../measures/ReachSingleArmMeasure.lua"
			}
			EffortMeasure {
				weight = 0.1
				measure_type = SquaredMuscleActivation
			}
		}
	}
}
