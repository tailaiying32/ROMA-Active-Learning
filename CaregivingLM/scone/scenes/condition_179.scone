CmaOptimizer {
	signature_prefix = DATE_TIME
	enable_boundary_transformer = 1
	random_seed = 42
	flat_fitness_epsilon = 1e-6
	window_size = 1000
	min_progress = 1e-5

	SimulationObjective {
		$rest_dur = 1
		$trg_dur = 1.5
		$react_dur = 1.0
		signature_postfix = T10
		max_duration = 3
		
		ModelHyfydyPrecise {
			model_file = ../models/HSA13T-2025-06-26.hfd
			state_init_file = ../init/InitHSA13_bs.zml
			fixed_control_step_size = 0.005
			zero_velocity_equilibration = 1
			
			model_options {
				use_legacy_pin_joints = 0
				joint_rotational_damping = 0.02
			}

			Properties {
				trap_scap_m_r {max_isometric_force.factor = 0.804587}
				trap_scap_s_r {max_isometric_force.factor = 0.778193}
				trap_scap_i_r {max_isometric_force.factor = 0.739507}
				trap_clav_s_r {max_isometric_force.factor = 0.764162}
				ser_ant_i_r {max_isometric_force.factor = 0.691081}
				ser_ant_m_r {max_isometric_force.factor = 0.769292}
				ser_ant_s_r {max_isometric_force.factor = 0.825270}
				rhom_s_r {max_isometric_force.factor = 0.730056}
				rhom_i_r {max_isometric_force.factor = 0.780150}
				lev_scap_r {max_isometric_force.factor = 0.766321}
				pect_min_r {max_isometric_force.factor = 0.132081}
				delt_clav_a_r {max_isometric_force.factor = 0.604120}
				delt_scap_p_r {max_isometric_force.factor = 0.838448}
				delt_scap_m_r {max_isometric_force.factor = 0.844481}
				lat_dors_m_r {max_isometric_force.factor = 0.808163}
				lat_dors_i_r {max_isometric_force.factor = 0.741981}
				pect_maj_clav_s_r {max_isometric_force.factor = 0.578874}
				pect_maj_thorax_i_r {max_isometric_force.factor = 0.764162}
				pect_maj_thorax_m_r {max_isometric_force.factor = 0.853412}
				teres_maj_r {max_isometric_force.factor = 0.705730}
				infraspi_i_r {max_isometric_force.factor = 0.746618}
				infraspi_s_r {max_isometric_force.factor = 0.702240}
				teres_min_r {max_isometric_force.factor = 0.835785}
				subscap_s_r {max_isometric_force.factor = 0.754618}
				subscap_i_r {max_isometric_force.factor = 0.705633}
				supraspi_r {max_isometric_force.factor = 0.728730}
				tri_long_r {max_isometric_force.factor = 0.700902}
				tri_lat_r {max_isometric_force.factor = 0.838761}
				coracobrach_r {max_isometric_force.factor = 0.642077}
				bic_long_r {max_isometric_force.factor = 0.707795}
				bic_brev_r {max_isometric_force.factor = 0.824761}
				brach_r {max_isometric_force.factor = 0.854057}
				brachiorad_r {max_isometric_force.factor = 0.838515}
				supinator_r {max_isometric_force.factor = 0.777986}
				pronator_teres_r {max_isometric_force.factor = 0.764162}
				ext_carpi_rad_long_r {max_isometric_force.factor = 0.719500}
				ext_carpi_rad_brev_r {max_isometric_force.factor = 0.736722}
				ext_carpi_ulna_r {max_isometric_force.factor = 0.758703}
				flex_carpi_rad_r {max_isometric_force.factor = 0.855541}
				flex_carpi_ulna_r {max_isometric_force.factor = 0.756835}
			}
		}
		
		# Sequential FeedForward Controller
		SequentialController {
			transition_intervals = [ $rest_dur ]
			FeedForwardController { name = Relax1 Constant { value = 0.01 } }
			
			FeedForwardController {
				include = "*_r"
				PieceWiseLinear {
					control_points = 2
					control_point_y = 0.015~0.001<0,1>
					control_point_dt = 0.4~0.01<0.1,1.0>
					flat_extrapolation = 1
				}
			}
		}
		
		# Reaching Measure
		CompositeMeasure {
			use_first_non_zero_result = 1
			ScriptMeasure {
				weight = 100
				threshold = 0.05
				vel_penalty = 0.2
				start_time = $rest_dur
				target_duration = $trg_dur
				react_time = $react_dur
				show_target = 1
				minimize = 1
				target_body = "hand_r"
				script_file = "../measures/ReachSingleArmMeasure.lua"
			}
			EffortMeasure {
				weight = 0.1
				measure_type = SquaredMuscleActivation
			}
		}
	}
}
