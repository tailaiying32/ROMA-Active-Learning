CmaOptimizer {
	signature_prefix = DATE_TIME
	enable_boundary_transformer = 1
	random_seed = 42
	flat_fitness_epsilon = 1e-6
	window_size = 1000
	min_progress = 1e-5

	SimulationObjective {
		$rest_dur = 1
		$trg_dur = 1.5
		$react_dur = 1.0
		signature_postfix = T10
		max_duration = 3
		
		ModelHyfydyPrecise {
			model_file = ../models/HSA13T-2025-06-26.hfd
			state_init_file = ../init/InitHSA13_bs.zml
			fixed_control_step_size = 0.005
			zero_velocity_equilibration = 1
			
			model_options {
				use_legacy_pin_joints = 0
				joint_rotational_damping = 0.02
			}

			Properties {
				trap_scap_m_r {max_isometric_force.factor = 0.734198}
				trap_scap_s_r {max_isometric_force.factor = 0.658349}
				trap_scap_i_r {max_isometric_force.factor = 0.750599}
				trap_clav_s_r {max_isometric_force.factor = 0.723551}
				ser_ant_i_r {max_isometric_force.factor = 0.707209}
				ser_ant_m_r {max_isometric_force.factor = 0.760015}
				ser_ant_s_r {max_isometric_force.factor = 0.816844}
				rhom_s_r {max_isometric_force.factor = 0.780657}
				rhom_i_r {max_isometric_force.factor = 0.698995}
				lev_scap_r {max_isometric_force.factor = 0.714215}
				pect_min_r {max_isometric_force.factor = 0.111776}
				delt_clav_a_r {max_isometric_force.factor = 0.582945}
				delt_scap_p_r {max_isometric_force.factor = 0.684012}
				delt_scap_m_r {max_isometric_force.factor = 0.794756}
				lat_dors_m_r {max_isometric_force.factor = 0.785646}
				lat_dors_i_r {max_isometric_force.factor = 0.767798}
				pect_maj_clav_s_r {max_isometric_force.factor = 0.540622}
				pect_maj_thorax_i_r {max_isometric_force.factor = 0.723551}
				pect_maj_thorax_m_r {max_isometric_force.factor = 0.761645}
				teres_maj_r {max_isometric_force.factor = 0.742146}
				infraspi_i_r {max_isometric_force.factor = 0.726286}
				infraspi_s_r {max_isometric_force.factor = 0.806808}
				teres_min_r {max_isometric_force.factor = 0.811882}
				subscap_s_r {max_isometric_force.factor = 0.747540}
				subscap_i_r {max_isometric_force.factor = 0.770732}
				supraspi_r {max_isometric_force.factor = 0.779659}
				tri_long_r {max_isometric_force.factor = 0.767334}
				tri_lat_r {max_isometric_force.factor = 0.742097}
				coracobrach_r {max_isometric_force.factor = 0.704499}
				bic_long_r {max_isometric_force.factor = 0.701761}
				bic_brev_r {max_isometric_force.factor = 0.788168}
				brach_r {max_isometric_force.factor = 0.669848}
				brachiorad_r {max_isometric_force.factor = 0.627202}
				supinator_r {max_isometric_force.factor = 0.702454}
				pronator_teres_r {max_isometric_force.factor = 0.723551}
				ext_carpi_rad_long_r {max_isometric_force.factor = 0.791559}
				ext_carpi_rad_brev_r {max_isometric_force.factor = 0.780099}
				ext_carpi_ulna_r {max_isometric_force.factor = 0.768991}
				flex_carpi_rad_r {max_isometric_force.factor = 0.727115}
				flex_carpi_ulna_r {max_isometric_force.factor = 0.814051}
			}
		}
		
		# Sequential FeedForward Controller
		SequentialController {
			transition_intervals = [ $rest_dur ]
			FeedForwardController { name = Relax1 Constant { value = 0.01 } }
			
			FeedForwardController {
				include = "*_r"
				PieceWiseLinear {
					control_points = 2
					control_point_y = 0.015~0.001<0,1>
					control_point_dt = 0.4~0.01<0.1,1.0>
					flat_extrapolation = 1
				}
			}
		}
		
		# Reaching Measure
		CompositeMeasure {
			use_first_non_zero_result = 1
			ScriptMeasure {
				weight = 100
				threshold = 0.05
				vel_penalty = 0.2
				start_time = $rest_dur
				target_duration = $trg_dur
				react_time = $react_dur
				show_target = 1
				minimize = 1
				target_body = "hand_r"
				script_file = "../measures/ReachSingleArmMeasure.lua"
			}
			EffortMeasure {
				weight = 0.1
				measure_type = SquaredMuscleActivation
			}
		}
	}
}
