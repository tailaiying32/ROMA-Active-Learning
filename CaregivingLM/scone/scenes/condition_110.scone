CmaOptimizer {
	signature_prefix = DATE_TIME
	enable_boundary_transformer = 1
	random_seed = 42
	flat_fitness_epsilon = 1e-6
	window_size = 1000
	min_progress = 1e-5

	SimulationObjective {
		$rest_dur = 1
		$trg_dur = 1.5
		$react_dur = 1.0
		signature_postfix = T10
		max_duration = 3
		
		ModelHyfydyPrecise {
			model_file = ../models/HSA13T-2025-06-26.hfd
			state_init_file = ../init/InitHSA13_bs.zml
			fixed_control_step_size = 0.005
			zero_velocity_equilibration = 1
			
			model_options {
				use_legacy_pin_joints = 0
				joint_rotational_damping = 0.02
			}

			Properties {
				trap_scap_m_r {max_isometric_force.factor = 0.085719}
				trap_scap_s_r {max_isometric_force.factor = 0.114922}
				trap_scap_i_r {max_isometric_force.factor = 0.053704}
				trap_clav_s_r {max_isometric_force.factor = 0.138717}
				ser_ant_i_r {max_isometric_force.factor = 0.219439}
				ser_ant_m_r {max_isometric_force.factor = 0.300852}
				ser_ant_s_r {max_isometric_force.factor = 0.115593}
				rhom_s_r {max_isometric_force.factor = 0.069982}
				rhom_i_r {max_isometric_force.factor = 0.047400}
				lev_scap_r {max_isometric_force.factor = 0.149916}
				pect_min_r {max_isometric_force.factor = 0.116474}
				delt_clav_a_r {max_isometric_force.factor = 0.904883}
				delt_scap_p_r {max_isometric_force.factor = 0.952672}
				delt_scap_m_r {max_isometric_force.factor = 0.908944}
				lat_dors_m_r {max_isometric_force.factor = 0.121907}
				lat_dors_i_r {max_isometric_force.factor = 0.115675}
				pect_maj_clav_s_r {max_isometric_force.factor = 0.106280}
				pect_maj_thorax_i_r {max_isometric_force.factor = 0.045742}
				pect_maj_thorax_m_r {max_isometric_force.factor = 0.131824}
				teres_maj_r {max_isometric_force.factor = 0.040408}
				infraspi_i_r {max_isometric_force.factor = 0.055329}
				infraspi_s_r {max_isometric_force.factor = 0.051277}
				teres_min_r {max_isometric_force.factor = 0.064805}
				subscap_s_r {max_isometric_force.factor = 0.199641}
				subscap_i_r {max_isometric_force.factor = 0.034016}
				supraspi_r {max_isometric_force.factor = 0.146978}
				tri_long_r {max_isometric_force.factor = 0.022798}
				tri_lat_r {max_isometric_force.factor = 0.132909}
				coracobrach_r {max_isometric_force.factor = 0.126373}
				bic_long_r {max_isometric_force.factor = 0.108907}
				bic_brev_r {max_isometric_force.factor = 0.028117}
				brach_r {max_isometric_force.factor = 0.400000}
				brachiorad_r {max_isometric_force.factor = 0.103076}
				supinator_r {max_isometric_force.factor = 0.122500}
				pronator_teres_r {max_isometric_force.factor = 0.290953}
				ext_carpi_rad_long_r {max_isometric_force.factor = 0.142257}
				ext_carpi_rad_brev_r {max_isometric_force.factor = 0.149620}
				ext_carpi_ulna_r {max_isometric_force.factor = 0.156864}
				flex_carpi_rad_r {max_isometric_force.factor = 0.148489}
				flex_carpi_ulna_r {max_isometric_force.factor = 0.070321}
			}
		}
		
		# Sequential FeedForward Controller
		SequentialController {
			transition_intervals = [ $rest_dur ]
			FeedForwardController { name = Relax1 Constant { value = 0.01 } }
			
			FeedForwardController {
				include = "*_r"
				PieceWiseLinear {
					control_points = 2
					control_point_y = 0.015~0.001<0,1>
					control_point_dt = 0.4~0.01<0.1,1.0>
					flat_extrapolation = 1
				}
			}
		}
		
		# Reaching Measure
		CompositeMeasure {
			use_first_non_zero_result = 1
			ScriptMeasure {
				weight = 100
				threshold = 0.05
				vel_penalty = 0.2
				start_time = $rest_dur
				target_duration = $trg_dur
				react_time = $react_dur
				show_target = 1
				minimize = 1
				target_body = "hand_r"
				script_file = "../measures/ReachSingleArmMeasure.lua"
			}
			EffortMeasure {
				weight = 0.1
				measure_type = SquaredMuscleActivation
			}
		}
	}
}
