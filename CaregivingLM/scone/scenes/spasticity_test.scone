CmaOptimizer {
	signature_prefix = DATE_TIME
	enable_boundary_transformer = 1
	random_seed = 42
	flat_fitness_epsilon = 1e-6
	window_size = 1000
	min_progress = 1e-5
	
	SimulationObjective {
		$rest_dur = 3
		$trg_dur = 1.5
		$react_dur = 1.0
		signature_postfix = T10
		max_duration = 6
		
		ModelHyfydyPrecise {
			model_file = ../models/HSA13T-2025-06-26.hfd
			state_init_file = ../init/InitHSA13_bs.zml
			fixed_control_step_size = 0.005
			zero_velocity_equilibration = 1
			
			model_options {
				use_legacy_pin_joints = 0
				joint_rotational_damping = 0.02
			}
			
			Properties {
				#bic_long_r {
				#	optimal_fiber_length.factor = 0.95
				#	tendon_slack_length.factor = 0.95
				#}
				#bic_brev_r {
				#	optimal_fiber_length.factor = 0.95
				#	tendon_slack_length.factor = 0.95
				#}
				tri_lat_r {
					max_isometric_force.factor = 0.6
				}
				tri_long_r {
					max_isometric_force.factor = 0.6
				}
			}
		}
		
		
		
		CompositeController {
				ReflexController {
					name = "tone_only_biceps"
					MuscleReflex { target = bic_long_r delay = 0.020 C0 = 0.1 KF = 1 }
					MuscleReflex { target = bic_brev_r delay = 0.020 C0 = 0.1 KF = 1 }
				}
		
				#ReflexController {
				#				name = "spastic_biceps_severe"
				#				MuscleReflex {
				#					target = "bic_long_r"
				#					C0 = 0.05
				#					KV = 4.0
				#					V0 = 0.06                 # only triggers at fast stretches
				#					KL = 0.20
				#					L0 = 0.98                 # slight length bias to trigger earlier
				#					KF = -0.05                # less inhibition can allow oscillations
				#					allow_neg_F = 1
				#					min_control_value = 0.0
				#					max_control_value = 1.0
				#					delay = 0.055
				#				}
				#				MuscleReflex {
				#					target = "bic_brev_r"
				#					C0 = 0.05
				#					KV = 4.0
				#					V0 = 0.06                 # only triggers at fast stretches
				#					KL = 0.20
				#					L0 = 0.98                 # slight length bias to trigger earlier
				#					KF = -0.05                # less inhibition can allow oscillations
				#					allow_neg_F = 1
				#					min_control_value = 0.0
				#					max_control_value = 1.0
				#					delay = 0.055
				#				}
				#			}
				# Sequential FeedForward Controller
				SequentialController {
					transition_intervals = [ $rest_dur ]
					FeedForwardController { name = Relax1 Constant { value = 0.01 } }
					
					FeedForwardController {
						include = "*_r"
						PieceWiseLinear {
							control_points = 2
							control_point_y = 0.015~0.001<0,1>
							control_point_dt = 0.4~0.01<0.1,1.0>
							flat_extrapolation = 1
						}
					}
				}
			}
			
			# Reaching Measure
			CompositeMeasure {
				use_first_non_zero_result = 1
				ScriptMeasure {
					weight = 100
					threshold = 0.05
					vel_penalty = 0.2
					start_time = $rest_dur
					target_duration = $trg_dur
					react_time = $react_dur
					show_target = 1
					minimize = 1
					target_body = "hand_r"
					script_file = "../measures/single_4.lua"
				}
				EffortMeasure {
					weight = 0.1
					measure_type = SquaredMuscleActivation
				}
			}
		}
	}
